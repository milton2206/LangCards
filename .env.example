# Ключ Anthropic (Claude) API. Хранится ТОЛЬКО на сервере — в браузер не попадает.
# Локально: скопируйте этот файл в .env.local и вставьте ключ (файл .env.local в .gitignore).
# На проде: задаётся в переменных окружения Vercel (Settings → Environment Variables).
ANTHROPIC_API_KEY=

# (необязательно) модель. По умолчанию claude-haiku-4-5 (самая дешёвая — для
# генерации карточек её качества достаточно). Можно переопределить, напр.:
# ANTHROPIC_MODEL=claude-sonnet-5

# ---------- Supabase (аккаунты пользователей) ----------
# Эти ДВЕ переменные ПУБЛИЧНЫЕ (префикс VITE_ — попадают в браузер, так и надо):
# anon-ключ не секрет, защита данных — через Row Level Security (см. supabase/schema.sql).
# Берутся в дашборде Supabase: Project Settings → API.
# Локально: в .env.local. На проде: Vercel → Settings → Environment Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ВНИМАНИЕ: секретный service_role ключ сюда НЕ добавлять и во фронтенд НЕ класть.
